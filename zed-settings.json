    "JSON": {
      "formatter": {
        "external": {
          "arguments": [
            "-S",
            "."
          ],
          "command": "jq"
        }
      }
    }
  },
  "project_panel": {
    "dock": "left"
  },
  "tab_size": 2,
  "theme": {
    "dark": "macOS Classic Dark",
    "light": "macOS Classic Light",
    "mode": "light"
  },
  "ui_font_size": 14
}
