{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git commit *)",
      "Bash(gh pr create *)",
      "Bash(gh pr edit *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh issue create *)",
      "Bash(gh issue edit *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(xcodebuild test *)",
      "Bash(swiftlint --quiet *)",
      "Bash(xcrun xccov *)",
      "Bash(xcrun simctl list *)"
    ],
    "deny": [
      "Bash(gws*)",
      "Bash(mail*)",
      "Bash(sendmail*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push -f *)",
      "Bash(git push *--force*)",
      "Bash(git push *--force-with-lease*)",
      "Bash(git push *-f)",
      "Bash(git push *-f *)",
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Read(**/secrets/**)",
      "Edit(**/secrets/**)",
      "Read(**/credentials.json)",
      "Edit(**/credentials.json)"
    ],
    "ask": [
      "Bash(curl* -X DELETE*)",
      "Bash(git push*)",
      "Bash(gcloud* delete*)",
      "Bash(gcloud* destroy*)",
      "Bash(aws* delete*)",
      "Bash(aws* terminate*)",
      "Bash(az* delete*)",
      "Bash(terraform* destroy*)",
      "Bash(npm publish*)",
      "Bash(pnpm add *)",
      "Bash(uv add *)",
      "Bash(uv pip install *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(brew install *)",
      "Bash(npm install -g *)",
      "Bash(npm install --global *)",
      "Bash(winget install *)",
      "Bash(dotnet tool install *)",
      "Bash(cargo install *)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,sys;exec(open(os.path.expanduser('~/.dotfiles/play-sound.py'),encoding='utf-8').read());play('notification')\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,sys;exec(open(os.path.expanduser('~/.dotfiles/play-sound.py'),encoding='utf-8').read());play('stop')\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "Japanese",
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": false,
  "theme": "light",
  "editorMode": "normal",
  "autoCompactEnabled": true
}
