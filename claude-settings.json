{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(xcodebuild test *)",
      "Bash(swiftlint --quiet *)",
      "Bash(xcrun xccov *)",
      "Bash(xcrun simctl list *)"
    ],
    "deny": [
      "Bash(gws*)",
      "Bash(mail*)",
      "Bash(sendmail*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Read(**/.env*)",
      "Edit(**/.env*)",
      "Read(**/secrets/**)",
      "Edit(**/secrets/**)",
      "Read(**/credentials.json)",
      "Edit(**/credentials.json)"
    ],
    "ask": [
      "Bash(curl* -X DELETE*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(gcloud* delete*)",
      "Bash(gcloud* destroy*)",
      "Bash(aws* delete*)",
      "Bash(aws* terminate*)",
      "Bash(az* delete*)",
      "Bash(terraform* destroy*)",
      "Bash(npm publish*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Funk.aiff"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "language": "Japanese",
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light",
  "editorMode": "normal",
  "autoCompactEnabled": true,
  "tui": "fullscreen"
}
